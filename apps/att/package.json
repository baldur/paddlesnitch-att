{
  "name": "att",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "next": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install --with-deps chromium",
    "seed": "tsx --env-file=.env.local scripts/seed.ts",
    "cognito": "cognito-local",
    "cognito:init": "tsx --env-file-if-exists=.env.local scripts/cognito-init.ts",
    "rivers": "tsx scripts/download-rivers.ts",
    "build:open-next": "npx open-next build",
    "deploy": "pnpm build:open-next && cd ../../infra && npm run deploy"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1086.0",
    "@paddlesnitch/core": "workspace:*",
    "@paddlesnitch/timing": "workspace:*",
    "@aws-sdk/client-cognito-identity-provider": "^3.1057.0",
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/client-ses": "^3.1056.0",
    "@aws-sdk/client-ssm": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@swc/helpers": "^0.5.21",
    "aws-jwt-verify": "^5.1.1",
    "fit-file-parser": "^3.0.0",
    "leaflet": "^1.9.4",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@opennextjs/aws": "^4.0.2",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-leaflet": "^3.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "cognito-local": "^5.3.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.3",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
