{
  "name": "paddlesnitch",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter att dev",
    "dev:analysis": "node scripts/dev-analysis.mjs",
    "build:analysis": "pnpm --filter analysis build",
    "next": "pnpm --filter att next",
    "build": "pnpm --filter att build",
    "start": "pnpm --filter att start",
    "lint": "pnpm --filter att lint",
    "test": "pnpm --filter att test",
    "test:watch": "pnpm --filter att test:watch",
    "e2e": "pnpm --filter att e2e",
    "e2e:ui": "pnpm --filter att e2e:ui",
    "e2e:install": "pnpm --filter att e2e:install",
    "seed": "pnpm --filter att seed",
    "cognito": "pnpm --filter att cognito",
    "cognito:init": "pnpm --filter att cognito:init",
    "rivers": "pnpm --filter att rivers",
    "build:open-next": "pnpm --filter att build:open-next"
  },
  "comment_devDependencies": "@aws-sdk/client-ses is hoisted to the workspace root so the infra-lambda vitest tests (importing infra/lambdas/*.mjs from outside any package) resolve it during `pnpm test`, which CI runs before infra/npm ci.",
  "devDependencies": {
    "@aws-sdk/client-ses": "^3.1056.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "aws-sdk",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
