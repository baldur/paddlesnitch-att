# Local development — copy to .env.local
NODE_ENV=development
USE_LOCAL_STORAGE=true   # use filesystem instead of S3
USE_DEV_AUTH=true        # bypass Cognito, use hardcoded dev user

# Production only (set in CDK/Lambda env — never commit real values)
# DATA_BUCKET=attsstack-databucket-xxxx
# PASSWORD_HASH_KEY=<generate with: openssl rand -hex 32>
