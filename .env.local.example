# Local development — copy to .env.local
NODE_ENV=development
USE_LOCAL_STORAGE=true   # use filesystem instead of S3
USE_DEV_AUTH=true        # bypass Cognito, use hardcoded dev user

# Production only (set in CDK/Lambda env)
# DATA_BUCKET=rrc-tt-data-prod
# USER_POOL_ID=us-east-1_xxxxx
# USER_POOL_CLIENT_ID=xxxxxxx
