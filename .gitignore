# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env.local
.env*.local

# scratch credential files (never commit)
strava.txt

# local data store (filesystem S3 substitute)
.local-data/

# cognito-local emulator state (user pool + users)
.cognito/

# downloaded static assets (run pnpm rivers to regenerate)
public/data/rivers.geojson

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.aider*
# CDK infra build artifacts
infra/dist/
infra/node_modules/
.open-next/
cdk.out/

# Playwright artifacts
playwright-report/
test-results/
/playwright/.cache/

# Agent worktrees + local scratch
.claude/
paddle-map-*.html
